Instalar Forwarder no Kali

***************************************
Script completo (coleta multi-log)
  Salve como: splunk_forwarder_multilog.sh
***************************************
#!/bin/bash

set -e

# ================================
# CONFIG
# ================================
VERSION="9.4.9"
BUILD="03bb451d4e07"
PKG="splunkforwarder-${VERSION}-${BUILD}-linux-amd64.deb"
URL="https://download.splunk.com/products/universalforwarder/releases/${VERSION}/linux/${PKG}"

SPLUNK_HOME="/opt/splunkforwarder"
SPLUNK_USER="splunkfwd"
SPLUNK_PASS="SenhaForte123!"
SPLUNK_IP="192.168.x.x"
SPLUNK_PORT="9997"

echo "[+] INICIANDO INSTALAÇÃO BLINDADA..."

# ================================
# 1. LIMPEZA SEGURA
# ================================
echo "[+] Limpando instalação antiga..."

sudo systemctl stop SplunkForwarder.service 2>/dev/null || true
sudo $SPLUNK_HOME/bin/splunk stop 2>/dev/null || true

sudo dpkg --purge splunkforwarder 2>/dev/null || true

sudo rm -rf $SPLUNK_HOME
sudo rm -f /etc/systemd/system/SplunkForwarder.service

sudo userdel $SPLUNK_USER 2>/dev/null || true

# ================================
# 2. USUÁRIO DEDICADO
# ================================
echo "[+] Criando usuário dedicado..."

sudo useradd -m -r -s /bin/false $SPLUNK_USER

# ================================
# 3. DOWNLOAD
# ================================
echo "[+] Baixando pacote..."

wget -q --show-progress -O $PKG $URL

# ================================
# 4. INSTALAÇÃO
# ================================
echo "[+] Instalando pacote..."

sudo dpkg -i $PKG

# ================================
# 5. PERMISSÕES CORRETAS
# ================================
echo "[+] Ajustando permissões..."

sudo chown -R $SPLUNK_USER:$SPLUNK_USER $SPLUNK_HOME

# ================================
# 6. CRIAR USUÁRIO SPLUNK (seed)
# ================================
echo "[+] Criando credenciais automáticas..."

sudo mkdir -p $SPLUNK_HOME/etc/system/local

cat <<EOF | sudo tee $SPLUNK_HOME/etc/system/local/user-seed.conf > /dev/null
[user_info]
USERNAME = admin
PASSWORD = $SPLUNK_PASS
EOF

sudo chown $SPLUNK_USER:$SPLUNK_USER $SPLUNK_HOME/etc/system/local/user-seed.conf

# ================================
# 7. START CORRETO (SEM ROOT)
# ================================
echo "[+] Iniciando Splunk como $SPLUNK_USER..."

sudo -u $SPLUNK_USER $SPLUNK_HOME/bin/splunk start --accept-license --answer-yes --no-prompt

# ================================
# 8. CONFIG FORWARD
# ================================
echo "[+] Configurando envio..."

sudo -u $SPLUNK_USER $SPLUNK_HOME/bin/splunk add forward-server ${SPLUNK_IP}:${SPLUNK_PORT} -auth admin:$SPLUNK_PASS

# ================================
# 9. MONITORAMENTO
# ================================
echo "[+] Adicionando logs..."

sudo -u $SPLUNK_USER $SPLUNK_HOME/bin/splunk add monitor /var/log/auth.log -auth admin:$SPLUNK_PASS
sudo -u $SPLUNK_USER $SPLUNK_HOME/bin/splunk add monitor /var/log/syslog -auth admin:$SPLUNK_PASS

# ================================
# 10. BOOTSTART CORRETO
# ================================
echo "[+] Configurando inicialização automática..."

sudo $SPLUNK_HOME/bin/splunk enable boot-start -user $SPLUNK_USER

# ================================
# 11. VALIDAÇÃO FINAL
# ================================
echo "[+] Validando instalação..."

sudo -u $SPLUNK_USER $SPLUNK_HOME/bin/splunk status
sudo -u $SPLUNK_USER $SPLUNK_HOME/bin/splunk list forward-server -auth admin:$SPLUNK_PASS

echo "[✔] INSTALAÇÃO BLINDADA CONCLUÍDA!"

